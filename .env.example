# Copy to .env and fill in. Never commit .env.

# 'sandbox' or 'production'. Develop against sandbox.
PROCORE_ENV=sandbox

# From your app in the Procore Developer Portal (https://developers.procore.com).
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=

# Must match the redirect URI registered on the Procore app EXACTLY.
# In production this is your deployed origin, e.g. https://drawbridge.onrender.com/api/auth/callback
PROCORE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Encrypts the session cookie. Generate with: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# Where the SPA is served from, used for CORS and post-login redirects.
# In production the server serves the SPA itself, so this is the SAME deployed origin,
# e.g. https://drawbridge.onrender.com (no separate web host).
WEB_ORIGIN=http://localhost:5173
PORT=3001

# Set NODE_ENV=production on the host. It makes the server (a) serve the built web/dist
# SPA from this same origin and (b) mark the session cookie Secure. Leave it unset locally.
# NODE_ENV=production

# OPTIONAL: LLM-assisted sheet number/title extraction. Leave LLM_API_KEY blank to keep
# the app on its local positional heuristics (fully functional without a key). Only sheet
# TEXT is sent to this provider — never the drawing file. Defaults target Groq's free tier
# (https://console.groq.com — no credit card, does not train on inputs). Cerebras is a
# drop-in alternative: set LLM_BASE_URL=https://api.cerebras.ai/v1 and an LLM_MODEL it serves.
LLM_API_KEY=
# LLM_BASE_URL=https://api.groq.com/openai/v1
# On Groq, only the gpt-oss models support the strict JSON-schema extraction this uses.
# LLM_MODEL=openai/gpt-oss-20b
